classDiagram
    class Task {
        +str description
        +str time
        +int duration_minutes
        +str frequency
        +str priority
        +bool completed
        +str due_date
        +mark_complete()
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task)
        +get_tasks()
        +task_count()
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet)
        +get_pet(name)
        +get_all_tasks()
    }

    class Scheduler {
        +Owner owner
        +sort_by_time()
        +sort_by_priority()
        +filter_by_status(completed)
        +filter_by_pet(pet_name)
        +detect_conflicts()
        +mark_task_complete(task)
        +get_todays_schedule()
        +format_schedule()
        +save_to_json(filepath)
        +load_from_json(filepath)$
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : reads tasks via
    Task ..> Task : next_occurrence() creates
